{
  "name": "correostest",
  "version": "1.0.0",
  "description": "Preparación oposición Correos — PWA + tutor IA",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel deploy --prod",
    "syntax-check": "node --check api/tutor.js && node --check js/tutor.js && node --check js/app.js",
    "build:www": "node scripts/build-www.mjs",
    "android:sync": "node scripts/build-www.mjs && cap sync android"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@capacitor-community/text-to-speech": "6.1.0"
  },
  "devDependencies": {
    "@capacitor/android": "7",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "7",
    "@capacitor/core": "7",
    "vercel": "^39.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
