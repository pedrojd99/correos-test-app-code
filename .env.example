# Anthropic API key — necesaria para los scripts de prompts engineered.
# Crea una en https://console.anthropic.com/
# Cópialo a .env y carga con `set -a; . ./.env; set +a` (bash) o
# `. .\.env` (PowerShell con dotenv equivalente). No subas .env al repo.
ANTHROPIC_API_KEY=sk-ant-...

# Resend — lista de aviso de convocatoria (/api/subscribe).
# API key en https://resend.com/api-keys; el Audience ID está en la URL
# de la audiencia creada en https://resend.com/audiences
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...
